source 'https://rubygems.org'

# Global gems (used across development, test, and production)
# gem 'xxxxx'

# Dependencies used only during development or running tests
group :development, :test do
  # A code linter and language server helper for RubyMine
  gem 'rubocop', require: false
end

# Dependencies strictly used for running your test suite
group :test do
  # The core Minitest testing framework
  gem 'minitest', '~> 6.0'

  # Optional: Gives you beautiful, colored test output in your terminal
  gem 'minitest-reporters'
end